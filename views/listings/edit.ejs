<% layout("/layouts/boilerplate")-%>


    <form method="POST" action="/listings/<%=listing._id%>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data" >
        <div class="row mt-3">
            <div class="col-8 offset-2">
        
        <h3>Edit listing</h3>
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
             <input itemid="title" class="form-control" id="title" type="text" value="<%=listing.title%>" required name="listing[title]">
        </div>
        <div class="mb-3">
            <label for="decsription" class="form-label">Description</label>
            <textarea id="decsription" class="form-control" required  name="listing[description]" placeholder="<%=listing.description%>" id="decsription"><%=listing.description%></textarea>
        </div>
        <div class="mb-3">
            Original Listing Image
            <br><br>
            <img src="<%=originalImageUrl%>"/>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Upload new Image</label>
            <input id="image" class="form-control" type="file"  name="listing[image]">
            
        </div>    
        <div class="row">
        <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input class="form-control" required id="price" type="number" name="listing[price]" placeholder="<%=listing.price%>">
        </div>
        <div class="mb-3 col-md-8">
            <label for="country"  class="form-label">Country</label>
            <input id="country" required class="form-control" type="text" name="listing[country]" placeholder="<%=listing.country%>" >
        </div>
        </div>


        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input class="form-control" required id="location" type="text" name="listing[location]" placeholder="<%=listing.location%>" type="text">
        </div>
        
        <button class="btn btn-dark edit-btn mt-3">Edit</button>

            </div>
        </div>
    </form>

